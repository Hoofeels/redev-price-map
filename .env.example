# === 국토교통부 실거래가 (공공데이터포털 data.go.kr) — US-004에서 사용 ===
# data.go.kr 회원가입 → "국토교통부_아파트 매매 실거래가 자료" 등 활용신청 → 일반 인증키(서비스키)
# 재개발 빌라·단독용으로 "연립다세대 매매", "단독/다가구 매매" 실거래가도 함께 신청 권장
MOLIT_API_KEY=

# === 지도 — 현재 basemap은 OpenStreetMap(키 불필요) ===
# 구역 지오코딩/지번/구역경계가 필요해지면 아래 키를 활용 (선택)
# Kakao Developers(developers.kakao.com) JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_KEY=
# VWorld(vworld.kr) 인증키 — 정비구역 경계 GIS에 유리 (선택)
VWORLD_API_KEY=

# === 서울 정비사업 데이터 — US-002 ===
# 정보몽땅(cleanup.seoul.go.kr) 스크래핑은 키 불필요. npm run scrape:seoul 로 data/seoul-zones.json 생성.
# (서울 열린데이터광장 OA-2253 OpenAPI는 2026-06-05 종료됨)

# === 경기 정비사업 데이터 — US-003 ===
# 경기데이터드림(data.gg.go.kr) "일반 정비사업 추진현황" 인증키
# npm run scrape:gyeonggi 로 data/gyeonggi-zones.json 생성 (--env-file=.env.local 로 키 로드)
GYEONGGI_API_KEY=
GYEONGGI_SERVICE_NAME=GenrlimprvBizpropls
